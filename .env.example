# ═══════════════════════════════════════════
# SocialSync Environment Variables
# Copy this file to .env.local and fill in values
# ═══════════════════════════════════════════

# ── Database ──────────────────────────────
DATABASE_URL="file:./dev.db"

# ── JWT Auth ──────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-min-10-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-this-min-10-chars"

# ── Server ────────────────────────────────
PORT=4000
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# ── OpenAI (AI Assistant) ─────────────────
OPENAI_API_KEY="sk-your-openai-key"

# ── Facebook Graph API ────────────────────
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_REDIRECT_URI="http://localhost:4000/api/platforms/facebook/callback"

# ── Twitter/X API ─────────────────────────
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
TWITTER_REDIRECT_URI="http://localhost:4000/api/platforms/twitter/callback"

# ── Pinterest API ─────────────────────────
PINTEREST_APP_ID=""
PINTEREST_APP_SECRET=""
PINTEREST_REDIRECT_URI="http://localhost:4000/api/platforms/pinterest/callback"

# ── Redis (for BullMQ scheduler) ──────────
REDIS_URL="redis://localhost:6379"
