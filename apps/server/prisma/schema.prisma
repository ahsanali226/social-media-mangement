// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── User ─────────────────────────────────
model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String?
  avatar       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  accounts     PlatformAccount[]
  posts        Post[]
}

// ── Connected Social Platform Account ────
model PlatformAccount {
  id           String         @id @default(cuid())
  userId       String
  platform     String         // FACEBOOK | TWITTER | PINTEREST
  platformId   String         // Platform-specific user/page ID
  accountName  String
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  metadata     String?        // JSON string for extra platform data
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts        PostPlatform[]

  @@unique([userId, platform, platformId])
}

// ── Post (cross-platform content) ────────
model Post {
  id          String         @id @default(cuid())
  userId      String
  content     String
  mediaUrls   String?        // JSON array of media URLs
  status      String         @default("DRAFT") // DRAFT | SCHEDULED | PUBLISHED | FAILED
  scheduledAt DateTime?
  publishedAt DateTime?
  aiGenerated Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platforms   PostPlatform[]
}

// ── Per-platform publish record ──────────
model PostPlatform {
  id             String           @id @default(cuid())
  postId         String
  accountId      String
  platformPostId String?          // ID returned after publishing
  status         String           @default("PENDING") // PENDING | PUBLISHED | FAILED
  errorMessage   String?
  publishedAt    DateTime?
  post           Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  account        PlatformAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}
